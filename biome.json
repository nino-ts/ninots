{
    "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
    "root": true,
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": ["**/*.ts", "**/*.tsx", "**/*.json", "!**/node_modules", "!**/dist", "!**/build", "!**/docs"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "lineEnding": "lf"
    },
    "assist": {
        "enabled": true,
        "actions": {
            "recommended": true
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noForEach": "error",
                "useArrowFunction": "error",
                "noUselessUndefinedInitialization": "error",
                "noUselessConstructor": "error",
                "useOptionalChain": "warn"
            },
            "correctness": {
                "noUnusedVariables": "error",
                "noUnusedImports": "error",
                "noUnusedFunctionParameters": "warn"
            },
            "style": {
                "noNonNullAssertion": "warn",
                "useConst": "error",
                "useBlockStatements": "error",
                "noParameterAssign": "error"
            },
            "suspicious": {
                "noExplicitAny": "warn",
                "noConsole": "warn"
            }
        }
    },
    "javascript": {
        "formatter": {
            "trailingCommas": "all",
            "arrowParentheses": "always",
            "bracketSpacing": true,
            "bracketSameLine": false,
            "semicolons": "always",
            "quoteStyle": "double"
        }
    }
}
