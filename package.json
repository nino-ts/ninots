{
    "name": "ninots-app",
    "version": "0.4.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun run --hot nino.ts serve",
        "start": "bun run nino.ts serve --prod",
        "build": "bun build --compile --bytecode nino.ts --outfile ninots",
        "nino": "bun run nino.ts",
        "docs:generate": "typedoc",
        "format": "bunx biome format --write .",
        "lint": "bunx biome check .",
        "lint:fix": "bunx biome check --write .",
        "lint:fix:unsafe": "bunx biome check --write --unsafe .",
        "test": "bun test"
    },
    "dependencies": {
        "@ninots/framework": "link:@ninots/framework",
        "@ninots/view": "link:@ninots/view"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@types/bun": "^1.3.13",
        "typescript": "^6.0.3"
    }
}
