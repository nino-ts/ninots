# App
APP_NAME="Ninots App"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000

# Server
PORT=3000
HOSTNAME=0.0.0.0

# Database
# Default (local + docker compose): SQLite file under storage/ (compose mounts a volume)
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ninots
DB_USERNAME=root
DB_PASSWORD=

# Optional Postgres (docker compose --profile postgres):
# DB_CONNECTION=postgres
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=ninots
# DB_USERNAME=ninots
# DB_PASSWORD=ninots

# Cache
CACHE_STORE=array

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# CSRF (set a strong secret in production)
CSRF_SECRET=change-me-in-production

# Queue (sync only — async drivers in a future sprint)
QUEUE_CONNECTION=sync
